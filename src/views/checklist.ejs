<h2 class="section-title">Solo Travel Packing Checklist</h2>
<p>
  Packing smart is vital for a solo trip. Because you carry your own bags, traveling light prevents muscle strain and makes boarding crowded ferries easy. Here is my recommended list of items. Check them off as you pack; your list will automatically save so you can return to it later.
</p>

<div class="checklist-container">
  <div class="checklist-header">
    <h3>My Packing Progress</h3>
    <button class="checklist-reset" id="btn-reset-checklist">Reset Checklist</button>
  </div>
  
  <!-- Live Progress Bar -->
  <div class="checklist-progress-container">
    <div id="checklist-progress-bar"></div>
  </div>

  <div class="checklist-grid" id="packing-checklist-grid">
    <label class="checklist-item">
      <input type="checkbox" data-item="passport-id">
      <span>Passport / National ID</span>
    </label>
    
    <label class="checklist-item">
      <input type="checkbox" data-item="power-bank">
      <span>Power Bank (High Capacity)</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="charger">
      <span>Phone Charger & Cable</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="umbrella">
      <span>Sturdy Umbrella</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="raincoat">
      <span>Light Raincoat / Poncho</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="shoes">
      <span>Comfortable Walking Shoes</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="medicine">
      <span>First-Aid & Basic Medicine</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="water-bottle">
      <span>Reusable Water Bottle</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="cash">
      <span>Emergency Cash (INR)</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="camera">
      <span>Mirrorless/DSLR Camera</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="sunglasses">
      <span>UV Sunglasses</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="hat">
      <span>Sun Hat / Cap</span>
    </label>

    <label class="checklist-item">
      <input type="checkbox" data-item="notebook">
      <span>Travel Journal & Pen</span>
    </label>
  </div>
</div>
